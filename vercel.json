{
  "version": 2,
  "builds": [
    { "src": "api/models.js", "use": "@vercel/node" },
    { "src": "api/recognize.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/models", "dest": "/api/models.js" },
    { "src": "/api/recognize", "dest": "/api/recognize.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
